COMPOSE_PROJECT_NAME=pixelproject

POSTGRES_DB=pixelproject
POSTGRES_USER=pixelproject
POSTGRES_PASSWORD=pixelproject
POSTGRES_PORT=5432

FRONTEND_PORT=3000
BACKEND_PORT=8000
REDIS_PORT=6379

APP_ENV=development
APP_NAME=PixelProject API
SECRET_KEY=change-me-in-local-dev
BACKEND_CORS_ORIGINS=http://localhost:3000
SQL_ECHO=false

DATABASE_URL=postgresql+asyncpg://pixelproject:pixelproject@db:5432/pixelproject
