COMPOSE_PROJECT_NAME=pixelproject

POSTGRES_DB=pixelproject
POSTGRES_USER=pixelproject
POSTGRES_PASSWORD=pixelproject
POSTGRES_PORT=5432

FRONTEND_PORT=3000
BACKEND_PORT=8000
REDIS_PORT=6379

APP_ENV=development
APP_NAME=PixelProject API
SECRET_KEY=change-me-in-local-dev
BACKEND_CORS_ORIGINS=http://localhost:3000
FRONTEND_APP_URL=http://localhost:3000
SQL_ECHO=false

DATABASE_URL=postgresql+asyncpg://pixelproject:pixelproject@db:5432/pixelproject
REDIS_URL=redis://redis:6379/0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
AUTH_SESSION_COOKIE_NAME=pixelproject_session
AUTH_SESSION_MAX_AGE_HOURS=720
AUTH_COOKIE_SECURE=false
HOLDERS_UNLIMITED_DEFAULT=true
HOLDER_START_AMOUNT=128
HOLDER_START_LIMIT=1000
HOLDER_REGENERATION_INTERVAL_SECONDS=10
CLAIM_AREA_START_LIMIT=1
NORMAL_PIXEL_START_AMOUNT=64
NORMAL_PIXEL_START_LIMIT=64
NORMAL_PIXEL_REGENERATION_INTERVAL_SECONDS=30
LEVEL_UP_HOLDERS_STEP=256

API_SERVER_URL=http://backend:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

WORLD_ORIGIN_X=-2000
WORLD_ORIGIN_Y=-2000
WORLD_CHUNK_SIZE=4000
WORLD_EXPANSION_BUFFER=0
WORLD_EXPANSION_CLAIM_FILL_RATIO=0.7
