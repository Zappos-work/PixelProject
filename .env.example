API_SERVER_URL=http://backend:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

WORLD_ORIGIN_X=0
WORLD_ORIGIN_Y=0
WORLD_CHUNK_SIZE=5000
WORLD_EXPANSION_BUFFER=5000
